#
# Aliases
#

alias ..="cd .."
alias ..2="cd ../.."
alias ..3="cd ../../.."
alias ..4="cd ../../../.."
alias ..5="cd ../../../../.."

alias sudo="sudo "
alias path='echo -e ${PATH//:/\\n}'
alias x+="chmod +x"
alias rm="rm -i"

alias get="curl -O -L"
alias getpage='wget --no-clobber --page-requisites --html-extension --convert-links --no-host-directories'

take() { mkdir -p $@ && cd ${@:$#} }

# Copy/paste
if [[ $(uname) == 'Darwin' ]]; then # macOS
  alias c="pbcopy"
  alias p="pbpaste"
else
  alias c="xclip -selection clipboard"
  alias p="xclip -selection clipboard -o"
fi

#
# Docker
#

alias dps="docker ps"
alias dpsa="docker ps -a"
alias dim="docker images"
alias dcu="docker-compose up -d"
alias dcd="docker-compose down"

drmc() {
  for exited_container in $(docker ps --all -q -f status=exited | awk '{print $1}'); do
    docker rm $exited_container
  done
}

drmid() {
  for dangling_img in $(docker images -q -f dangling=true | awk '{print $1}'); do
    docker rmi $dangling_img
  done
}

dl() { docker logs -f $1 }
dsr() { docker stop "$@";docker rm "$@" }
drun() { docker run -it $1 ${2:/bin/bash} }